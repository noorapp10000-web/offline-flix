<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- الثيم الرئيسي -->
    <style name="Theme.OfflineFlix" parent="Theme.Material3.DynamicColors.DayNight">
        <item name="colorPrimary">#00C4FF</item>
        <item name="colorPrimaryVariant">#7B2FFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#7B2FFF</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">#0D0D1A</item>
        <item name="colorSurface">#13131F</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:windowBackground">#0D0D1A</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#0D0D1A</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- ثيم Splash Screen — Android 12+ API 31 -->
    <style name="Theme.OfflineFlix.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D0D1A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">3000</item>
        <item name="postSplashScreenTheme">@style/Theme.OfflineFlix</item>
    </style>
</resources>
