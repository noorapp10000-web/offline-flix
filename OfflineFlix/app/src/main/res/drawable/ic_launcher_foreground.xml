<?xml version="1.0" encoding="utf-8"?>
<!-- شعار OfflineFlix — حرف O + مثلث Play بتدرج Cyan → Purple -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- الحلقة (حرف O) بتدرج لوني Cyan → Purple -->
    <group>
        <clip-path
            android:pathData="M54,54m-46,0a46,46 0,1 1,92 0a46,46 0,1 1,-92 0"/>
        <path
            android:pathData="M54,54m-38,0a38,38 0,1 1,76 0a38,38 0,1 1,-76 0"
            android:fillColor="#00000000"
            android:strokeWidth="16">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="8"
                    android:startY="20"
                    android:endX="100"
                    android:endY="88"
                    android:type="linear">
                    <item android:offset="0" android:color="#FF00C4FF"/>
                    <item android:offset="1" android:color="#FF7B2FFF"/>
                </gradient>
            </aapt:attr>
        </path>
    </group>

    <!-- مثلث Play أبيض -->
    <path
        android:pathData="M44,38 L44,70 L74,54 Z"
        android:fillColor="#FFFFFF"/>

</vector>
